#!/usr/bin/env bash
# fanout — fan a GitHub parent issue's OPEN children out into dmux panes.
#
# Background: dmux v5.6.3 (the current npm latest) does NOT ship the HTTP API
# that its context/API.md describes. We drive pane creation through the dmux
# TUI via `tmux send-keys` against the control pane for the session.
#
# See ./README.md for the full design notes.

set -euo pipefail

readonly FANOUT_TAG_PREFIX='[fanout #'

default_sleep_between=4
default_wait_timeout=60
default_popup_timeout=20

usage() {
  cat <<'EOF'
Usage: fanout <parent-issue> [options]

Creates one dmux pane per OPEN sub-issue of <parent-issue>. Each pane gets a
dedicated git worktree (dmux handles that) and starts the configured agent
with a briefing that points at /tmp/fanout-<repo>-<num>.md.

Options:
  --agent <name>      Agent to launch (claude|codex|opencode|...). Required
                      unless the caller's tmux pane is itself a dmux-managed
                      pane — in that case fanout auto-detects the agent from
                      dmux.config.json. dmux v5.6.3 always opens an agent-
                      choice popup after the prompt popup, so fanout must
                      know the agent name to inject into it.
  --limit <N>         Cap how many children to enqueue this run. Remainder is
                      printed with a rerun command.
  --session <name>    Target a specific tmux session (required when more than
                      one dmux session is alive on this machine).
  --sleep <seconds>   Pause between pane-creation requests. Default 4. Raise
                      this if dmux reports "pane creation failed" under load.
  --popup-timeout <s> Seconds to wait for each dmux popup (new-pane, agent-
                      choice) to appear after the triggering keystroke.
                      Default 20. Raise on slow machines or large worktrees
                      where dmux takes longer than that between closing the
                      prompt popup and opening the agent-choice popup.
  --dry-run           Print the send-keys commands, the popup JSON payloads
                      that would be injected, and the briefings, without
                      driving dmux.
  --debug             Log intercept steps (popup PID, result file path, JSON
                      payload) to stderr as each pane is created.
  -h, --help          Show this message.

Prerequisites:
  * gh, gh-sub-issue extension, jq, tmux, pgrep installed.
  * `cd <repo> && dmux` has been run; tmux session is alive.
  * dmux TUI is on the pane-list view (no modal open). fanout sends one Esc
    at startup as a best-effort.
  * --agent given, OR the caller's pane is a dmux-managed pane so fanout
    can auto-detect it. dmux v5.6.3 routes new-pane prompts through
    tmux display-popup (a separate tmux client that send-keys cannot
    reach), so fanout drives the flow by intercepting the popup's result
    file. The agent name is required to satisfy the picker popup that
    dmux always shows next.

Exit codes:
  0 success (including "no children, nothing to do")
  1 prerequisite / environment problem
  2 bad invocation
EOF
}

# --- color helpers -----------------------------------------------------------

if [[ -t 1 ]] && command -v tput >/dev/null 2>&1 && [[ "${TERM:-dumb}" != dumb ]]; then
  C_INFO=$(tput setaf 4)
  C_OK=$(tput setaf 2)
  C_WARN=$(tput setaf 3)
  C_ERR=$(tput setaf 1)
  C_DIM=$(tput dim 2>/dev/null || true)
  C_RESET=$(tput sgr0)
else
  C_INFO=''; C_OK=''; C_WARN=''; C_ERR=''; C_DIM=''; C_RESET=''
fi

log_info()  { printf '%s[info]%s %s\n'  "$C_INFO"  "$C_RESET" "$*"; }
log_ok()    { printf '%s[ ok ]%s %s\n'  "$C_OK"    "$C_RESET" "$*"; }
log_warn()  { printf '%s[warn]%s %s\n'  "$C_WARN"  "$C_RESET" "$*" >&2; }
log_err()   { printf '%s[err ]%s %s\n'  "$C_ERR"   "$C_RESET" "$*" >&2; }
log_dim()   { printf '%s%s%s\n'         "$C_DIM"   "$*"        "$C_RESET"; }
log_debug() { (( ${debug:-0} )) || return 0; printf '%s[dbg ]%s %s\n' "$C_DIM" "$C_RESET" "$*" >&2; }

die() {
  log_err "$*"
  exit 1
}

# --- arg parsing -------------------------------------------------------------

parent=''
agent=''
limit=''
session_arg=''
sleep_between=$default_sleep_between
popup_timeout=$default_popup_timeout
dry_run=0
debug=0

while (( $# > 0 )); do
  case "$1" in
    -h|--help)    usage; exit 0 ;;
    --agent)      agent="${2:-}";     shift 2 || die "--agent requires an argument" ;;
    --limit)      limit="${2:-}";     shift 2 || die "--limit requires an argument" ;;
    --session)    session_arg="${2:-}"; shift 2 || die "--session requires an argument" ;;
    --sleep)      sleep_between="${2:-}"; shift 2 || die "--sleep requires an argument" ;;
    --popup-timeout) popup_timeout="${2:-}"; shift 2 || die "--popup-timeout requires an argument" ;;
    --dry-run)    dry_run=1;          shift ;;
    --debug)      debug=1;            shift ;;
    --)           shift; break ;;
    -*)
      log_err "unknown option: $1"
      usage >&2
      exit 2
      ;;
    *)
      if [[ -z "$parent" ]]; then
        parent="$1"
      else
        log_err "unexpected positional argument: $1"
        usage >&2
        exit 2
      fi
      shift
      ;;
  esac
done

if [[ -z "$parent" ]]; then
  usage >&2
  exit 2
fi
if ! [[ "$parent" =~ ^[0-9]+$ ]]; then
  die "parent issue must be an integer, got: $parent"
fi
if [[ -n "$limit" ]] && ! [[ "$limit" =~ ^[1-9][0-9]*$ ]]; then
  die "--limit must be a positive integer, got: $limit"
fi
if ! [[ "$sleep_between" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
  die "--sleep must be a number, got: $sleep_between"
fi
if ! [[ "$popup_timeout" =~ ^[1-9][0-9]*$ ]]; then
  die "--popup-timeout must be a positive integer (seconds), got: $popup_timeout"
fi

# --- dependency check --------------------------------------------------------

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || return 1
}

missing_deps=()
need_cmd gh    || missing_deps+=('gh (brew install gh)')
need_cmd jq    || missing_deps+=('jq (brew install jq)')
need_cmd tmux  || missing_deps+=('tmux (brew install tmux)')
need_cmd pgrep || missing_deps+=('pgrep (procps-ng on Linux; preinstalled on macOS)')

if ! gh extension list 2>/dev/null | cut -f1 | grep -qx 'gh sub-issue'; then
  missing_deps+=('gh-sub-issue extension (gh extension install yahsan2/gh-sub-issue)')
fi

if (( ${#missing_deps[@]} > 0 )); then
  log_err "missing dependencies:"
  for d in "${missing_deps[@]}"; do
    printf '  - %s\n' "$d" >&2
  done
  exit 1
fi

# --- dmux session discovery --------------------------------------------------

tmux_opt() {
  # $1 session, $2 option name. Returns empty string if unset.
  tmux show-options -v -t "$1" "$2" 2>/dev/null || true
}

gh_in_root() {
  (cd "$project_root" && gh "$@")
}

pid_alive() {
  [[ -n "$1" ]] && [[ "$1" =~ ^[0-9]+$ ]] && kill -0 "$1" 2>/dev/null
}

session_is_dmux() {
  local s="$1"
  local pid
  pid=$(tmux_opt "$s" '@dmux_controller_pid')
  pid_alive "$pid"
}

if ! tmux list-sessions -F '#{session_name}' >/dev/null 2>&1; then
  die "no tmux server is running. Start dmux in your repo first: cd <repo> && dmux"
fi

all_sessions=()
while IFS= read -r _s; do
  all_sessions+=("$_s")
done < <(tmux list-sessions -F '#{session_name}')

dmux_sessions=()
for s in "${all_sessions[@]}"; do
  if session_is_dmux "$s"; then
    dmux_sessions+=("$s")
  fi
done

if (( ${#dmux_sessions[@]} == 0 )); then
  die "no active dmux session found. Start one with: cd <repo> && dmux"
fi

if [[ -n "$session_arg" ]]; then
  found=0
  for s in "${dmux_sessions[@]}"; do
    if [[ "$s" == "$session_arg" ]]; then
      found=1
      break
    fi
  done
  (( found )) || die "tmux session '$session_arg' is not running dmux. Active dmux sessions: ${dmux_sessions[*]}"
  session="$session_arg"
elif (( ${#dmux_sessions[@]} > 1 )); then
  die "multiple dmux sessions active (${dmux_sessions[*]}); pass --session <name> to pick one"
else
  session="${dmux_sessions[0]}"
fi

control_pane=$(tmux_opt "$session" '@dmux_control_pane')
config_path=$(tmux_opt  "$session" '@dmux_config_path')
project_root=$(tmux_opt "$session" '@dmux_project_root')

[[ -n "$control_pane" ]] || die "session '$session' has no @dmux_control_pane option; dmux may be in a broken state"
[[ -n "$config_path"  ]] || die "session '$session' has no @dmux_config_path option"
[[ -n "$project_root" ]] || die "session '$session' has no @dmux_project_root option"

if [[ ! -f "$config_path" ]]; then
  die "dmux config not found at $config_path (session reports it but file is missing)"
fi

log_info "dmux session: $session"
log_info "control pane: $control_pane"
log_info "project root: $project_root"
log_info "config:       $config_path"

# --- agent auto-detect -------------------------------------------------------
# If --agent was not explicit, look up the caller's tmux pane in
# dmux.config.json and inherit its .agent field. This makes the agent-picker
# popup navigation work out of the box when /fanout is invoked from inside a
# dmux-managed agent session.
if [[ -z "$agent" ]] && [[ -n "${TMUX_PANE:-}" ]]; then
  detected_agent=$(jq -r --arg pid "$TMUX_PANE" '
    (.panes // [])
    | map(select(.paneId == $pid))
    | (.[0].agent // empty)
  ' "$config_path" 2>/dev/null || true)
  if [[ -n "$detected_agent" ]]; then
    agent="$detected_agent"
    log_info "auto-detected agent: $agent (from calling pane $TMUX_PANE)"
  fi
fi

# --- fetch sub-issues --------------------------------------------------------

# gh auto-detects the repo from cwd, so we'll chdir to project_root for the
# sub-issue call. Sanity-check that cwd is actually a work tree.
if ! (cd "$project_root" 2>/dev/null && git rev-parse --is-inside-work-tree >/dev/null 2>&1); then
  die "project root $project_root is not a git work tree; cannot resolve GitHub repo"
fi

log_info "fetching sub-issues of #$parent"
sub_issues_raw=$(gh_in_root sub-issue list "$parent" --json number,title,state 2>&1) \
  || die "gh sub-issue list failed: $sub_issues_raw"

# gh-sub-issue v0.5.x wraps as {"subIssues":[...]} with lowercase state and
# no body field; flatten + upcase to match downstream filters.
children_json=$(jq '[.subIssues // [] | .[] | {number, title, state: (.state | ascii_upcase), body: ""}]' <<<"$sub_issues_raw")

# Also union children declared as task-list items in the parent body; some
# parents list them there without using the Sub-issues API.
parent_body=$(gh_in_root issue view "$parent" --json body -q .body 2>/dev/null) || {
  log_warn "could not read parent body (#$parent); skipping task-list scan"
  parent_body=''
}

# `- [ ]` guard: skip prose mentions. `[^\w/]` guard: skip owner/repo#NUM.
body_nums=$(printf '%s' "$parent_body" | jq -Rrs '
  split("\n")
  | map(select(test("^[[:space:]]*-[[:space:]]+\\[[ xX]\\]")))
  | map([scan("(?:^|[^\\w/])#([0-9]+)") | .[0]])
  | flatten | map(tonumber) | unique | .[]
')

# Same sentinel-wrapped set idiom as fanned_set below so " 42 " membership
# doesn't false-match "142".
existing_set=' '
while IFS= read -r _n; do
  [[ -n "$_n" ]] && existing_set+="$_n "
done < <(jq -r '.[].number' <<<"$children_json")

body_details=()
for num in $body_nums; do
  [[ "$num" == "$parent" ]] && continue
  [[ "$existing_set" == *" $num "* ]] && continue
  detail=$(gh_in_root issue view "$num" --json number,title,state,body 2>/dev/null) || {
    log_warn "parent body references #$num but issue lookup failed; skipping"
    continue
  }
  body_details+=("$detail")
done

if (( ${#body_details[@]} > 0 )); then
  extra_json=$(printf '%s\n' "${body_details[@]}" | jq -s '.')
  children_json=$(jq --argjson extra "$extra_json" '. + $extra' <<<"$children_json")
  log_info "parent body added ${#body_details[@]} extra child reference(s) not in sub-issue API"
fi

# Count & filter.
total_children=$(jq 'length' <<<"$children_json")
if (( total_children == 0 )); then
  log_info "no sub-issues on #$parent. nothing to do."
  exit 0
fi

open_children_json=$(jq -c '[.[] | select(.state == "OPEN")]' <<<"$children_json")
open_count=$(jq 'length' <<<"$open_children_json")

log_info "sub-issues: $total_children total, $open_count OPEN"

if (( open_count == 0 )); then
  log_info "no OPEN sub-issues. nothing to do."
  exit 0
fi

# --- idempotency: find existing fanout-tagged panes --------------------------

existing_nums=$(jq -r --arg prefix "$FANOUT_TAG_PREFIX" '
  (.panes // [])
  | map(.prompt // "")
  | map(capture("^\\[fanout #(?<n>[0-9]+)\\]"; "g") | .n // empty)
  | .[]
' "$config_path" 2>/dev/null || true)

# Build a flat "set" of already-fanned numbers, space-delimited and sentinel-
# wrapped so " 42 " membership tests work without false positives on "142".
fanned_set=' '
if [[ -n "$existing_nums" ]]; then
  while IFS= read -r n; do
    [[ -n "$n" ]] && fanned_set+="$n "
  done <<<"$existing_nums"
fi

# --- split into targets / skipped -------------------------------------------

all_rows=()
while IFS= read -r _row; do
  all_rows+=("$_row")
done < <(jq -c '.[]' <<<"$open_children_json")

targets=()
skipped=()
for row in "${all_rows[@]}"; do
  num=$(jq -r '.number' <<<"$row")
  if [[ "$fanned_set" == *" $num "* ]]; then
    skipped+=("$num")
  else
    targets+=("$row")
  fi
done

if (( ${#targets[@]} == 0 )); then
  log_ok "all ${#skipped[@]} OPEN sub-issue(s) already have a fanout pane. nothing to do."
  exit 0
fi

# --- apply limit -------------------------------------------------------------

deferred=()
if [[ -n "$limit" ]] && (( ${#targets[@]} > limit )); then
  deferred=("${targets[@]:limit}")
  targets=("${targets[@]:0:limit}")
fi

if (( ${#skipped[@]} > 0 )); then
  log_info "already fanned-out (skipping): #${skipped[*]}"
fi
log_info "will create ${#targets[@]} pane(s); deferred: ${#deferred[@]}"

# --- briefing file builder ---------------------------------------------------

repo_slug=$(basename "$project_root")

briefing_path() {
  printf '/tmp/fanout-%s-%s.md' "$repo_slug" "$1"
}

write_briefing() {
  local num="$1" title="$2" body="$3"
  local path
  path=$(briefing_path "$num")
  cat >"$path" <<EOF
You are assigned GitHub issue #$num in this repository.

Title: $title

Body:
$body

Requirements:
- You are working inside a git worktree that was prepared for this task. Do not create additional worktrees.
- Make focused, minimal changes scoped to this single issue.
- Run the project's lint/test commands if they exist (inspect package.json / Makefile / pyproject.toml first).
- When implementation passes tests, commit and push the branch.
- Open a pull request with "Closes #$num" in the body.
- If the scope is ambiguous, stop and leave a comment on the issue instead of guessing.
EOF
  printf '%s' "$path"
}

# --- tmux driving ------------------------------------------------------------

tmux_send_keys() {
  # Fire named keys at the dmux control pane. Only used to trigger the
  # new-pane popup (Escape + n) — the actual prompt delivery happens via
  # popup result-file injection, not send-keys, because dmux v5.6.3 renders
  # its new-pane prompt inside `tmux display-popup` which is a separate
  # tmux client that send-keys cannot address.
  if (( dry_run )); then
    printf '    %s$ tmux send-keys -t %s %s%s\n' "$C_DIM" "$control_pane" "$*" "$C_RESET"
    return 0
  fi
  tmux send-keys -t "$control_pane" "$@"
}

panes_len() {
  jq '(.panes // []) | length' "$config_path" 2>/dev/null || printf '0'
}

wait_for_new_pane() {
  local baseline="$1" deadline
  deadline=$(( $(date +%s) + default_wait_timeout ))
  while (( $(date +%s) < deadline )); do
    local cur
    cur=$(panes_len)
    if (( cur > baseline )); then
      return 0
    fi
    sleep 0.5
  done
  return 1
}

# --- dmux popup intercept ----------------------------------------------------
# dmux v5.6.3 drives input via `tmux display-popup -E 'node <popup>.js
# <resultFile> [args]'`. The popup writes its user-entered answer to
# <resultFile> as JSON; the dmux parent reads that file when the popup child
# exits. We piggyback on that contract: trigger the popup, find its PID and
# its resultFile from ps argv, atomically write our own JSON to the file,
# and kill the popup process. dmux sees a "successful submission" and
# proceeds as if a human had typed the answer.
#
# newPanePopup payload:     {"success":true,"data":"<prompt>"}
# agentChoicePopup payload: {"success":true,"data":["<agent>"]}
#
# dmux always launches agentChoicePopup after newPanePopup closes with a
# non-empty prompt (see selectAgentsForPaneCreation in DmuxApp.js), even
# when only one agent is enabled — so both must be intercepted per issue.

popup_pid_baseline() {
  # Space-sentinel-wrapped set of PIDs matching any dmux popup script, so
  # find_new_popup can tell "already running before we started" from "just
  # spawned by our `n` keystroke".
  local pids=' ' pid
  while IFS= read -r pid; do
    [[ -n "$pid" ]] && pids+="$pid "
  done < <(pgrep -f '/popups/.*Popup\.js' 2>/dev/null || true)
  printf '%s' "$pids"
}

find_new_popup() {
  # $1 script-name fragment (e.g. 'newPanePopup\.js')
  # $2 baseline PID set
  # $3 timeout tenths of a second (default 50 = 5s)
  # Prints "<pid>\t<resultFile>" on success, returns 1 on timeout.
  #
  # `pgrep -f` matches the full argv, so for a single popup dmux spawns it
  # typically hits FOUR processes that all carry the script path: the outer
  # `sh -c` dmux spawns, the `tmux display-popup` it runs, the inner shell
  # tmux creates, and finally the Node.js popup. Killing anything but the
  # Node process leaves the real popup orphaned on the tmux client, which
  # lets dmux advance (it sees its spawned child exit and reads the result
  # file we wrote) while blocking the next `display-popup` from opening —
  # exactly the "popup 1 succeeds, popup 2 never appears" failure mode we
  # kept hitting. Filter on COMM so only the Node popup is returned.
  local pattern="$1" baseline="$2" max_iters="${3:-50}"
  local i=0 pid args rf comm
  while (( i < max_iters )); do
    while IFS= read -r pid; do
      [[ -z "$pid" ]] && continue
      [[ "$baseline" == *" $pid "* ]] && continue
      comm=$(ps -o comm= -p "$pid" 2>/dev/null) || continue
      # macOS BSD ps returns the full path; procps-ng returns the basename.
      # Normalize so `/usr/local/bin/node`, `node`, `node24` all match.
      [[ "$(basename "$comm")" == node* ]] || continue
      args=$(ps -o args= -p "$pid" 2>/dev/null) || continue
      rf=$(grep -oE '[[:alnum:]/_.-]+/dmux-popup-[0-9]+\.json' <<<"$args" | head -1)
      if [[ -n "$rf" ]]; then
        printf '%s\t%s\n' "$pid" "$rf"
        return 0
      fi
    done < <(pgrep -f "$pattern" 2>/dev/null)
    sleep 0.1
    i=$(( i + 1 ))
  done
  return 1
}

write_popup_result() {
  # Atomic write: tmp-in-same-dir then rename. dmux only reads the file
  # after the popup child exits, so as long as we rename before killing
  # the child, the read sees a complete payload.
  local path="$1" payload="$2"
  local tmp="${path}.fanout.tmp"
  printf '%s' "$payload" >"$tmp"
  mv -f "$tmp" "$path"
}

make_newpane_result() {
  jq -cn --arg p "$1" '{success:true, data:$p}'
}

make_agent_result() {
  jq -cn --arg a "$1" '{success:true, data:[$a]}'
}

intercept_popup() {
  # $1 pattern, $2 baseline, $3 payload, $4 human label, $5 timeout (tenths)
  # Returns 0 if the popup was found + payload written + process killed.
  local pattern="$1" baseline="$2" payload="$3" label="$4" timeout="${5:-50}"
  local line pid rf
  if ! line=$(find_new_popup "$pattern" "$baseline" "$timeout"); then
    log_err "  $label popup did not appear within $(( timeout / 10 ))s"
    return 1
  fi
  pid="${line%%$'\t'*}"
  rf="${line#*$'\t'}"
  log_debug "$label popup pid=$pid resultFile=$rf"
  # Give dmux's PopupWrapper time to mount and write its readyFile so the
  # parent's readyPromise (utils/popup.js::waitForPopupReady) resolves via
  # the ready-file path rather than via child.close after we kill. 150ms
  # comfortably covers the React Ink useEffect tick; it is negligible next
  # to --sleep's rate-limit gap.
  sleep 0.15
  write_popup_result "$rf" "$payload"
  log_debug "$label wrote: $payload"
  kill "$pid" 2>/dev/null || true
  log_debug "$label killed pid=$pid"
}

create_pane_for_issue() {
  local num="$1" title="$2" body="$3"
  local briefing
  briefing=$(write_briefing "$num" "$title" "$body")

  local short_title="${title:0:60}"
  local one_line_prompt
  printf -v one_line_prompt '%s%s] %s: read %s and begin.' \
    "$FANOUT_TAG_PREFIX" "$num" "$short_title" "$briefing"

  log_info "#$num: $short_title"
  log_dim "  briefing -> $briefing"

  local baseline
  baseline=$(panes_len)

  local newpane_payload agent_payload
  newpane_payload=$(make_newpane_result "$one_line_prompt")
  agent_payload=''
  [[ -n "$agent" ]] && agent_payload=$(make_agent_result "$agent")

  if (( dry_run )); then
    printf '  %sbriefing size%s: %d bytes\n' "$C_DIM" "$C_RESET" "$(wc -c <"$briefing")"
    printf '  %scurrent panes[] length%s: %s\n' "$C_DIM" "$C_RESET" "$baseline"
    tmux_send_keys Escape
    tmux_send_keys n
    printf '    %s# would intercept newPanePopup and write: %s%s\n' "$C_DIM" "$newpane_payload" "$C_RESET"
    if [[ -n "$agent_payload" ]]; then
      printf '    %s# would intercept agentChoicePopup and write: %s%s\n' "$C_DIM" "$agent_payload" "$C_RESET"
    else
      printf '    %s# WOULD FAIL: agent is empty (pass --agent or run from a dmux pane)%s\n' "$C_WARN" "$C_RESET"
    fi
    log_ok "#$num: dry-run complete"
    return 0
  fi

  if [[ -z "$agent_payload" ]]; then
    log_err "#$num: no agent resolved. dmux v5.6.3 always shows the agent-choice popup after the prompt popup, so fanout needs an agent name. Pass --agent <name> or invoke fanout from a dmux-managed pane."
    return 1
  fi

  local pid_baseline
  pid_baseline=$(popup_pid_baseline)

  tmux_send_keys Escape
  sleep 0.2
  tmux_send_keys n

  intercept_popup 'newPanePopup\.js' "$pid_baseline" "$newpane_payload" '  newPanePopup' "$(( popup_timeout * 10 ))" \
    || return 1

  # The agent-choice popup is spawned after dmux reads the first resultFile.
  # Refresh baseline to exclude the just-killed PID and anything unrelated.
  pid_baseline=$(popup_pid_baseline)

  intercept_popup 'agentChoicePopup\.js' "$pid_baseline" "$agent_payload" '  agentChoicePopup' "$(( popup_timeout * 10 ))" \
    || return 1

  if wait_for_new_pane "$baseline"; then
    log_ok "#$num: pane created (panes[] now $(panes_len))"
    return 0
  else
    log_err "#$num: timed out after ${default_wait_timeout}s waiting for config.json to grow"
    return 1
  fi
}

# --- main loop ---------------------------------------------------------------

created=0
failed=0
for row in "${targets[@]}"; do
  num=$(jq -r '.number' <<<"$row")
  title=$(jq -r '.title' <<<"$row")
  body=$(jq -r '.body // ""' <<<"$row")
  if [[ -z "$body" ]]; then
    body=$(gh_in_root issue view "$num" --json body -q .body 2>/dev/null || printf '')
  fi

  if create_pane_for_issue "$num" "$title" "$body"; then
    created=$(( created + 1 ))
  else
    failed=$(( failed + 1 ))
    log_warn "stopping early — manual inspection needed"
    break
  fi

  # don't sleep after the last one
  if (( created + failed < ${#targets[@]} )); then
    sleep "$sleep_between"
  fi
done

# --- summary -----------------------------------------------------------------

printf '\n'
if (( created > 0 )); then log_ok   "created: $created"; fi
if (( failed > 0 )); then log_err  "failed:  $failed"; fi
if (( ${#skipped[@]} > 0 )); then log_info "skipped (already fanned-out): ${#skipped[@]}"; fi

if (( ${#deferred[@]} > 0 )); then
  printf '\n%sDeferred %d issue(s) due to --limit. Rerun with:%s\n' "$C_INFO" "${#deferred[@]}" "$C_RESET"
  deferred_nums=()
  for row in "${deferred[@]}"; do
    deferred_nums+=("#$(jq -r '.number' <<<"$row")")
  done
  printf '  %s\n' "${deferred_nums[*]}"
  agent_flag=''
  [[ -n "$agent" ]] && agent_flag=" --agent $agent"
  session_flag=''
  [[ -n "$session_arg" ]] && session_flag=" --session $session_arg"
  printf '  fanout %s --limit %d%s%s\n' "$parent" "${#deferred[@]}" "$agent_flag" "$session_flag"
fi

(( failed > 0 )) && exit 1
exit 0
