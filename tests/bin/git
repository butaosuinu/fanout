#!/usr/bin/env bash
# Tier 2 shim: short-circuit fanout:504's
# `(cd "$project_root" && git rev-parse --is-inside-work-tree)` probe.
#
# Tier 2 fixtures advertise a project_root via the tmux shim's
# @dmux_project_root option, but that directory is synthetic — there's no
# `.git` inside it. Rather than seed every fixture with a real git
# worktree, we answer "yes, it's a work tree" here.
#
# Any other `git <...>` invocation is delegated to the real `git` so that
# helpers.bash's own git calls (e.g. in CI) keep working. The passthrough
# walks $PATH and picks the first `git` that isn't this shim itself, so
# it's robust to CI environments where `/usr/bin/git` may or may not be
# canonical.

set -euo pipefail

if [[ "${1:-}" == "rev-parse" && "${2:-}" == "--is-inside-work-tree" ]]; then
  exit 0
fi

self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

IFS=:
for d in $PATH; do
  cand="$d/git"
  [[ -x "$cand" ]] || continue
  cand_resolved="$(cd "$(dirname "$cand")" 2>/dev/null && pwd)/$(basename "$cand")"
  [[ "$cand_resolved" == "$self" ]] && continue
  # SC2093: exec inside a loop looks suspicious to shellcheck because code
  # can follow, but that's the intent — the fallback `exit 127` below runs
  # only when no candidate matched and we never exec'd.
  # shellcheck disable=SC2093
  exec "$cand" "$@"
done

echo "git shim: no real git found on PATH" >&2
exit 127
